@page
@model IndexModel
@{
    ViewData["Title"] = "Mi Agenda";
}

<div class="text-center mt-4">
    <h1 style="color: #68217a; font-weight: bold;">📇 Mi Agenda Web</h1>
    <p class="text-muted">Proyecto desde cero en Visual Studio</p>
</div>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="text-end mb-3">
                <a asp-page="/AgregarContacto" class="btn text-white" style="background: #68217a;">
                    + Nuevo Contacto
                </a>
            </div>

            <div class="table-responsive">
                <table class="table table-hover bg-white shadow-sm">
                    <thead style="background: #68217a; color: white;">
                        <tr>
                            <th>Nombre</th>
                            <th>Teléfono</th>
                            <th>Correo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in IndexModel.ListaContactos)
                        {
                        <tr>
                            <td>@c.Nombre</td>
                            <td>@c.Telefono</td>
                            <td>@c.Correo</td>
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>