@page
@model MiAgendaWeb.Pages.Login.IndexModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Portal Estelar de Acceso</title>
    <link rel="stylesheet" href="~/css/Style.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="flex items-center justify-center p-4 bg-black min-h-screen">

    <div id="auth-container" class="glass-card w-full max-w-md p-8 rounded-xl shadow-2xl border border-white/10">

        <header class="text-center mb-10">
            <div class="inline-block p-3 rounded-full bg-purple-600/30 mb-4">
                <i data-lucide="rocket" class="w-8 h-8 text-purple-400"></i>
            </div>
            <h1 class="text-4xl font-extrabold text-white tracking-tight">Acceso al Portal</h1>
            <p class="text-gray-300 mt-2">Introduce tus credenciales cósmicas.</p>
        </header>

        <form method="post">
            <div class="mb-5">
                <label class="block text-sm font-medium text-gray-300">Email de Navegación</label>
                <input type="email" asp-for="Email" required
                       class="w-full p-3 bg-white/5 text-white rounded-lg border border-gray-700 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition-all"
                       placeholder="nombre@galaxia.com">
            </div>

            <div class="mb-5">
                <label class="block text-sm font-medium text-gray-300">Clave Estelar</label>
                <input type="password" asp-for="Password" required
                       class="w-full p-3 bg-white/5 text-white rounded-lg border border-gray-700 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition-all"
                       placeholder="••••••••">
            </div>

            @if (ViewData["ErrorMessage"] != null)
            {
                <div class="py-2 px-4 bg-red-500/20 border border-red-500 text-red-500 rounded-lg text-sm mb-4 animate-pulse">
                    <i data-lucide="alert-circle" class="w-4 h-4 inline mr-2"></i>
                    @ViewData["ErrorMessage"]
                </div>
            }

            <button type="submit" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 rounded-lg shadow-lg shadow-purple-500/30 transition-all duration-300 active:scale-95">
                Iniciar Sesión
            </button>
        </form>

        <footer class="mt-8 text-center text-gray-400 text-sm border-t border-white/5 pt-6">
            <p>
                ¿Primera vez en esta galaxia? <br>
                <a href="#" class="text-purple-400 hover:text-purple-300 font-semibold underline decoration-purple-500/30 underline-offset-4">¡Crea un nuevo tripulante!</a>
            </p>
        </footer>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>