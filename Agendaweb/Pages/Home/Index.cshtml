@page
@model MiAgendaWeb.Pages.Home.IndexModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Lobby - MiAgendaWeb</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-gray-50 min-h-screen font-sans">
    <nav class="bg-white border-b border-gray-200 p-4 shadow-sm">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <span class="text-2xl font-bold text-purple-800">MiAgenda<span class="text-purple-600">Web</span></span>
            <a href="/Login" class="text-red-500 hover:bg-red-50 px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2 border border-red-100 transition-all">
                <i data-lucide="log-out" class="w-4 h-4"></i> Cerrar Sesión
            </a>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto p-8">
        <div class="mb-10 flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="text-center md:text-left">
                <h1 class="text-4xl font-black text-gray-900 tracking-tight">Panel Principal</h1>
                <p class="text-gray-500 mt-2">Bienvenido, Admin. ¿Qué deseas gestionar hoy?</p>
            </div>

            @* --- NUEVA SECCIÓN: BUSCADOR GLOBAL Y ACCIONES --- *@
            <div class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
                <form method="get" asp-page="/Index" class="relative group">
                    <i data-lucide="search" class="w-5 h-5 absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-purple-500 transition-colors"></i>
                    <input type="text" name="searchTerm" placeholder="Buscar contacto..."
                           class="pl-10 pr-4 py-3 bg-white border border-gray-200 rounded-2xl w-full sm:w-64 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent shadow-sm transition-all">
                </form>
                <button class="bg-white border border-gray-200 p-3 rounded-2xl text-gray-600 hover:text-red-600 hover:border-red-100 hover:bg-red-50 transition-all shadow-sm" title="Exportar PDF">
                    <i data-lucide="file-text" class="w-6 h-6"></i>
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

            <div class="group bg-white p-8 rounded-3xl border border-gray-100 shadow-sm hover:shadow-xl hover:border-purple-200 transition-all cursor-pointer">
                <div class="w-14 h-14 bg-purple-100 text-purple-600 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-purple-600 group-hover:text-white transition-all">
                    <i data-lucide="users" class="w-7 h-7"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Mis Contactos</h3>
                <p class="text-gray-500 text-sm mb-6">Administra, busca y edita toda tu red de contactos de la base de datos.</p>
                <a href="/Index" class="inline-flex items-center gap-2 text-purple-600 font-bold hover:gap-4 transition-all text-sm uppercase tracking-widest">
                    Entrar ahora <i data-lucide="arrow-right" class="w-4 h-4"></i>
                </a>
            </div>

            @* --- NUEVA TARJETA: FAVORITOS --- *@
            <div class="group bg-white p-8 rounded-3xl border border-gray-100 shadow-sm hover:shadow-xl hover:border-yellow-200 transition-all cursor-pointer">
                <div class="w-14 h-14 bg-yellow-100 text-yellow-600 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-yellow-500 group-hover:text-white transition-all">
                    <i data-lucide="star" class="w-7 h-7"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Favoritos</h3>
                <p class="text-gray-500 text-sm mb-6">Acceso rápido a los contactos que más utilizas frecuentemente.</p>
                <a href="/Index?onlyFavorites=true" class="inline-flex items-center gap-2 text-yellow-600 font-bold hover:gap-4 transition-all text-sm uppercase tracking-widest">
                    Ver favoritos <i data-lucide="chevron-right" class="w-4 h-4"></i>
                </a>
            </div>

            <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm opacity-60">
                <div class="w-14 h-14 bg-blue-100 text-blue-600 rounded-2xl flex items-center justify-center mb-6">
                    <i data-lucide="bar-chart-3" class="w-7 h-7"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Reportes</h3>
                <p class="text-gray-500 text-sm mb-6">Próximamente: Gráficas de crecimiento y actividad de tu agenda.</p>
                <span class="text-xs font-bold text-blue-400 uppercase tracking-widest">En desarrollo</span>
            </div>

        </div>
    </main>

    <script>lucide.createIcons();</script>
</body>
</html>